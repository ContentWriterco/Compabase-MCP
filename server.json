{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ContentWriterco/compabase",
  "title": "Compabase",
  "description": "MCP server for 3M+ Polish companies — KRS & CEIDG financials, ownership, and industry search.",
  "version": "1.0.0",
  "websiteUrl": "https://compabase.com/mcp",
  "repository": {
    "url": "https://github.com/ContentWriterco/Compabase-MCP",
    "source": "github",
    "id": "1258422770"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://compabase.com/api/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Compabase MCP key (mcpk_...) from https://compabase.com/mcp",
          "isRequired": true,
          "isSecret": true,
          "format": "string",
          "placeholder": "Bearer mcpk_YOUR_KEY_HERE"
        }
      ]
    }
  ]
}
